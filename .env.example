APP_NAME="ISUFST CICT"
APP_ENV=local
APP_KEY=REDACTED_APP_KEY
APP_CIPHER=aes-256-cbc
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

LOCAL_DEV=true
# Use a DATABASE_URL or split into DB_* variables
DATABASE_URL=REDACTED_DATABASE_URL
DB_CONNECTION=pgsql
DB_HOST=REDACTED_DB_HOST
DB_PORT=5432
DB_DATABASE=REDACTED_DB_DATABASE
DB_USERNAME=REDACTED_DB_USERNAME
DB_PASSWORD=REDACTED_DB_PASSWORD
DB_SSLMODE=require

SESSION_DRIVER=file
SESSION_LIFETIME=1440
SESSION_ENCRYPT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=supabase
QUEUE_CONNECTION=database

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="ISUFST CICT"

AWS_ACCESS_KEY_ID=REDACTED_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REDACTED_AWS_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=products
AWS_ENDPOINT=REDACTED_AWS_ENDPOINT
AWS_URL=REDACTED_AWS_URL
AWS_USE_PATH_STYLE_ENDPOINT=true

SUPABASE_ANON_KEY=REDACTED_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REDACTED_SUPABASE_SERVICE_ROLE_KEY

VITE_APP_NAME="CICT-Dingle"
GEMINI_API_KEY=REDACTED_GEMINI_API_KEY
GEMINI_MODEL=gemini-3-flash-preview

# OAuth Configuration
# Get Google credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=REDACTED_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REDACTED_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# NOTE: Do NOT commit real secrets. Use environment variables or a secrets manager.APP_NAME="CICT Store"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database (Supabase PostgreSQL via Pooler - IPv4 compatible)
# Get this from: Supabase Dashboard → Database → Connection Pooling → Session Mode
DB_CONNECTION=pgsql
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DB_SSLMODE=require

# Application / Session
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Cache / Queue
CACHE_STORE=database
QUEUE_CONNECTION=sync

# Mail
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="CICT Store"

# Storage (Supabase S3-compatible)
FILESYSTEM_DISK=supabase
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=products
AWS_ENDPOINT=https://[project-ref].supabase.co/storage/v1/s3
AWS_URL=https://[project-ref].supabase.co/storage/v1/object/public
AWS_USE_PATH_STYLE_ENDPOINT=true

# Supabase REST API keys
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Gemini API (Google)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Optional: Third party keys
SENTRY_DSN=
VITE_APP_NAME="CICT Store"

# DO NOT STORE PRODUCTION SECRETS HERE. This example file is intentionally blank.
